# ─── Frontend (safe to expose — these are PUBLIC keys) ───────────────
# Copy this file to `.env` and fill in your values.
# Get them from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Edge Function secrets (server-side ONLY — do NOT put in frontend) ─
# These are set with `supabase secrets set ...`, NOT in this .env.
# Listed here only for reference:
#   R2_ACCOUNT_ID=...
#   R2_ACCESS_KEY_ID=...
#   R2_SECRET_ACCESS_KEY=...
#   R2_BUCKET=gowtham-wedding
#   R2_PUBLIC_URL=https://media.your-domain.com   (your R2 public/custom domain)
